<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Detalles de Clase</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">

    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>
    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-xl w-full max-w-4xl">
        
        <div class="flex justify-between items-center border-b pb-4 mb-6">
            <h1 class="text-3xl font-bold text-teal-800">📘 Ficha de la Materia</h1>
            <span class="bg-teal-100 text-teal-800 text-sm font-semibold px-3 py-1 rounded">ID Clase: {{claseId}}</span>
        </div>

        <div class="mb-8 bg-gray-50 p-6 rounded-lg border border-gray-200">
            <h2 class="text-2xl font-bold text-gray-800 mb-2">{{claseNombre}}</h2>
            <p class="text-gray-600 whitespace-pre-wrap">{{claseDescripcion}}</p>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}
        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <div class="bg-blue-50 p-6 rounded-lg border border-blue-200 mb-8">
            <h3 class="text-lg font-bold text-blue-800 mb-3">➕ Añadir Alumno a la Clase</h3>
            <form action="/profesor/clases/alumnos/agregar" method="post" class="flex gap-4 items-end">
                <input type="hidden" name="clase_id" value="{{claseId}}">
                <div class="flex-grow">
                    <label for="user_id" class="block text-gray-700 text-sm font-medium mb-1">Seleccione un estudiante de la base de datos:</label>
                    <select id="user_id" name="user_id" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                        <option value="" disabled selected>-- Alumnos disponibles --</option>
                        {{#alumnosDisponibles}}
                            <option value="{{usuarioId}}">ID: {{usuarioId}} - {{nombre}}</option>
                        {{/alumnosDisponibles}}
                        {{^alumnosDisponibles}}
                            <option value="" disabled>No hay alumnos disponibles para agregar.</option>
                        {{/alumnosDisponibles}}
                    </select>
                </div>
                <button type="submit" class="bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition duration-300 font-bold shadow-md h-10">
                    Inscribir
                </button>
            </form>
        </div>

        <h3 class="text-xl font-bold text-gray-800 mb-4">👥 Alumnos Inscritos Actualmente</h3>
        <div class="overflow-x-auto border border-gray-200 rounded-lg mb-8 shadow-sm">
            <table class="min-w-full bg-white">
                <thead class="bg-teal-100 border-b border-teal-200">
                    <tr>
                        <th class="py-3 px-4 text-left text-teal-800 font-bold">ID Alumno</th>
                        <th class="py-3 px-4 text-left text-teal-800 font-bold">Nombre Completo</th>
                        <th class="py-3 px-4 text-center text-teal-800 font-bold">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#alumnosInscritos}}
                    <tr class="hover:bg-gray-50 border-b border-gray-100">
                        <td class="py-3 px-4 text-gray-600">{{usuarioId}}</td>
                        <td class="py-3 px-4 text-gray-800 font-semibold">{{nombre}}</td>
                        <td class="py-3 px-4 text-center">
                            <form action="/profesor/clases/alumnos/remover" method="post" class="inline">
                                <input type="hidden" name="clase_id" value="{{claseId}}">
                                <input type="hidden" name="inscripcion_id" value="{{inscripcionId}}">
                                <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm font-bold transition duration-300">
                                    Expulsar
                                </button>
                            </form>
                        </td>
                    </tr>
                    {{/alumnosInscritos}}
                    
                    {{^alumnosInscritos}}
                    <tr>
                        <td colspan="3" class="py-6 text-center text-gray-500 italic">La clase está vacía. Inscribe un alumno usando el panel superior.</td>
                    </tr>
                    {{/alumnosInscritos}}
                </tbody>
            </table>
        </div>

        <div class="text-center">
            <a href="/profesor/clases/lista" class="inline-block bg-teal-600 text-white py-2 px-8 rounded-md hover:bg-teal-700 transition duration-300 font-bold shadow-md">
                Volver al selector de clases
            </a>
        </div>
    </div>
</body>
</html>