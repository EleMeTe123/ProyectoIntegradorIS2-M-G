<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Administrador</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">
    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Administración</h1>

        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-5 mb-8 rounded-lg shadow-sm" role="alert">
            <p class="font-bold text-xl text-center">Administrador</p>
            <p class="text-center">Tienes acceso total a las herramientas de gestión.</p>
        </div>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span></p>
        {{/username}}

        <div class="flex justify-center mb-8">
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm w-full max-w-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row justify-center gap-4 mb-4">
            <a href="/profesor/alta" class="bg-blue-600 text-white py-2 px-8 rounded-md hover:bg-blue-700 transition duration-300 text-lg text-center">Cargar nuevo profesor</a>
            <a href="/profesor/borrar" class="bg-red-600 text-white py-2 px-8 rounded-md hover:bg-red-700 transition duration-300 text-lg text-center">Borrar profesor</a>
        </div>
        <div class="flex justify-center mb-6">
            <a href="/admin/usuarios" class="bg-purple-600 text-white py-2 px-8 rounded-md hover:bg-purple-700 transition duration-300 text-lg text-center font-semibold border border-purple-800 shadow-sm">
                Opciones Avanzadas
            </a>
        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>
