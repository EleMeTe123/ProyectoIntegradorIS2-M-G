<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Configuraciones</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">
    
    <!-- reloj en tiempo real con javascript (codigo reciclado de StackOverflow) -->
    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>

    <script>
        function actualizarReloj() {
            
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        
        
        actualizarReloj();
        
        setInterval(actualizarReloj, 1000);
    </script>
    
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Configuración del Sistema</h1>
        
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mb-6">
            <h2 class="text-xl font-semibold mb-4">Preferencias de {{username}}</h2>
            <p class="text-gray-600 mb-4">Aquí podrás ajustar las opciones de tu cuenta en el futuro.</p>
            
            <div class="space-y-4">
                
                <div class="flex items-center justify-between p-3 bg-blue-50 rounded border border-blue-100">
                    <span class="text-gray-700">Fecha del servidor</span>
                    <span class="text-blue-800 font-bold">{{fechaActual}}</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-blue-50 rounded border border-blue-100">
                    <span class="text-gray-700">Hora de acceso</span>
                    <span class="text-blue-800 font-bold">{{horaActual}}</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-white rounded border">
                    <span>Notificaciones por correo</span>
                    <span class="text-green-600 font-bold">Activado</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-white rounded border">
                    <span>Idioma</span>
                    <span class="text-blue-600 font-bold">Español</span>
                </div>
            </div>
        </div>

        <div class="text-center">
            <a href="/dashboard" class="inline-block bg-gray-600 text-white py-2 px-6 rounded-md hover:bg-gray-700 transition duration-300">
                Volver al Panel
            </a>
        </div>
    </div>
</body>
</html>