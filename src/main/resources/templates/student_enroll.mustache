<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscripción a Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">
    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Inscripción a Materias</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span></p>
        {{/username}}

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        {{#hasSubjects}}
        <div class="space-y-3">
            {{#subjects}}
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded border border-gray-200">
                <div>
                    <p class="font-semibold text-gray-800">{{name}}</p>
                    <p class="text-sm text-gray-500">Código: {{code}}</p>
                </div>
                {{#enrolled}}
                <span class="text-green-600 font-semibold">Inscripto</span>
                {{/enrolled}}
                {{^enrolled}}
                <form action="/student/enroll" method="post">
                    <input type="hidden" name="subjectId" value="{{id}}">
                    <button type="submit" class="bg-blue-600 text-white py-1 px-4 rounded-md hover:bg-blue-700 transition duration-300 text-sm">
                        Inscribirse
                    </button>
                </form>
                {{/enrolled}}
            </div>
            {{/subjects}}
        </div>
        {{/hasSubjects}}
        {{^hasSubjects}}
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded">
            <p class="text-sm text-yellow-700">No hay materias disponibles.</p>
        </div>
        {{/hasSubjects}}

        <div class="text-center mt-6">
            <a href="/dashboard" class="inline-block bg-gray-600 text-white py-2 px-6 rounded-md hover:bg-gray-700 transition duration-300">Volver al Panel</a>
        </div>
    </div>
</body>
</html>
