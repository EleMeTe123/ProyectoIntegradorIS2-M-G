<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Borrar Profesor</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">
    
    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>
    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Borrar Profesor</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/profesor/borrar" method="post" class="space-y-6">
            <div>
                <label for="profesor_id" class="block text-gray-700 text-sm font-medium mb-2">Seleccione el profesor a eliminar:</label>
                
                <select id="profesor_id" name="profesor_id" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 bg-white">
                    <option value="" disabled selected>-- Elegir un profesor --</option>
                    
                    {{#profesores}}
                        <option value="{{id}}">{{nombre}} {{apellido}} - DNI: {{dni}}</option>
                    {{/profesores}}
                    
                    {{^profesores}}
                        <option value="" disabled>No hay profesores registrados</option>
                    {{/profesores}}
                </select>
            </div>

            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
                <p class="text-sm text-yellow-700"><strong>Advertencia:</strong> Esta acción eliminará al profesor de la base de datos de manera permanente.</p>
            </div>

            <div class="flex gap-4 mt-6">
                <a href="/dashboard" class="w-1/2 bg-gray-500 text-white py-2 px-4 rounded-md hover:bg-gray-600 text-center transition duration-300 flex items-center justify-center">
                    Cancelar
                </a>
                <button type="submit" class="w-1/2 bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300">
                    Eliminar
                </button>
            </div>
        </form>
    </div>
</body>
</html>