<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mis Clases</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">

    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>
    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-xl w-full max-w-md">
        <h1 class="text-3xl font-bold text-center text-teal-800 mb-6">🔍 Seleccionar Clase</h1>

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/profesor/clases/detalle" method="get" class="space-y-6">
            <div>
                <label for="clase_id" class="block text-gray-700 text-sm font-medium mb-2">Elija la materia que desea visualizar:</label>
                
                <select id="clase_id" name="clase_id" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
                    <option value="" disabled selected>-- Mis Clases Creadas --</option>
                    {{#clases}}
                        <option value="{{idClase}}">{{nombre}}</option>
                    {{/clases}}
                    {{^clases}}
                        <option value="" disabled>No tienes clases creadas aún.</option>
                    {{/clases}}
                </select>
            </div>

            <div class="flex gap-4 mt-8">
                <a href="/profesor/clases" class="w-1/2 bg-gray-500 text-white py-2 px-4 rounded-md hover:bg-gray-600 text-center transition duration-300 flex items-center justify-center font-bold">
                    Atrás
                </a>
                <button type="submit" class="w-1/2 bg-teal-600 text-white py-2 px-4 rounded-md hover:bg-teal-700 transition duration-300 font-bold shadow-md">
                    Ver Detalles
                </button>
            </div>
        </form>
    </div>
</body>
</html>