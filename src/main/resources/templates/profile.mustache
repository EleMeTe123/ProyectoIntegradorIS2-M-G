<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">
    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Mi Perfil</h1>

        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
            <h3 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Datos de la Cuenta</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <p class="text-sm text-gray-500">Nombre de Usuario</p>
                    <p class="font-medium text-gray-800">{{userName}}</p>
                </div>
                <div>
                    <p class="text-sm text-gray-500">Nombre</p>
                    <p class="font-medium text-gray-800">{{firstName}}</p>
                </div>
                <div>
                    <p class="text-sm text-gray-500">Apellido</p>
                    <p class="font-medium text-gray-800">{{lastName}}</p>
                </div>
                <div>
                    <p class="text-sm text-gray-500">DNI</p>
                    <p class="font-medium text-gray-800">{{dni}}</p>
                </div>
                <div class="md:col-span-2">
                    <p class="text-sm text-gray-500">Correo Electrónico</p>
                    <p class="font-medium text-gray-800">{{email}}</p>
                </div>
                {{#phoneNumber}}
                <div>
                    <p class="text-sm text-gray-500">Teléfono</p>
                    <p class="font-medium text-gray-800">{{phoneNumber}}</p>
                </div>
                {{/phoneNumber}}
                {{#address}}
                <div>
                    <p class="text-sm text-gray-500">Dirección</p>
                    <p class="font-medium text-gray-800">{{address}}</p>
                </div>
                {{/address}}
            </div>
        </div>

        <div class="flex justify-center mt-8">
            <a href="/dashboard" class="inline-block bg-gray-600 text-white py-2 px-6 rounded-md hover:bg-gray-700 transition duration-300 text-center">
                Volver al Panel
            </a>
        </div>
    </div>
</body>
</html>
