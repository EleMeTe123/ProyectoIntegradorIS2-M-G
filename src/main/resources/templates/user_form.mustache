<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Crear Cuenta</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[url('https://images.unsplash.com/photo-1477346611705-65d1883cee1e?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-no-repeat flex items-center justify-center min-h-screen p-4">
    <!-- reloj en tiempo real con javascript (codigo reciclado de StackOverflow) -->
    <div id="reloj-vivo" class="fixed top-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-md shadow-lg font-mono text-xl font-bold z-50 border border-gray-700">
        00:00:00
    </div>

    <script>
        function actualizarReloj() {
            
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            
            document.getElementById('reloj-vivo').textContent = `${horas}:${minutos}:${segundos}`;
        }
        
        
        actualizarReloj();
        
        setInterval(actualizarReloj, 1000);
    </script>

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Crear una cuenta</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/user/new" method="post" class="space-y-4">
            <div>
                <label for="userName" class="block text-gray-700 text-sm font-medium mb-1">Nombre de Usuario (*):</label>
                <input type="text" id="userName" name="userName" required placeholder="Ej: rgonzales"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="password" class="block text-gray-700 text-sm font-medium mb-1">Contraseña (*):</label>
                <input type="password" id="password" name="password" required minlength="6" placeholder="Ej: Password"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="firstName" class="block text-gray-700 text-sm font-medium mb-1">Nombre:</label>
                <input type="text" id="firstName" name="firstName" placeholder="Ej: Rafael"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="lastName" class="block text-gray-700 text-sm font-medium mb-1">Apellido:</label>
                <input type="text" id="lastName" name="lastName" placeholder="Ej: Gonzales"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="email" class="block text-gray-700 text-sm font-medium mb-1">Correo electrónico:</label>
                <input type="email" id="email" name="email" placeholder="hola@gmail.com"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="dni" class="block text-gray-700 text-sm font-medium mb-1">DNI:</label>
                <input type="text" id="dni" name="dni" pattern="\d*" title="Solo números." placeholder="Ej: 12345678"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="address" class="block text-gray-700 text-sm font-medium mb-1">Dirección:</label>
                <input type="text" id="address" name="address" placeholder="Ej: Calle paloma 2000"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="phoneNumber" class="block text-gray-700 text-sm font-medium mb-1">Teléfono:</label>
                <input type="text" id="phoneNumber" name="phoneNumber" pattern="\d*" title="Solo números." placeholder="Ej: 3582222888"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <p class="text-xs text-gray-500">(*) Campos obligatorios.</p>
            <div class="flex gap-4 mt-6">
                <a href="/"
                   class="w-1/2 bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 text-center focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
                    Cancelar
                </a>
                <button type="submit"
                        class="w-1/2 bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                    Registrar Usuario
                </button>
            </div>
            <div class="text-center mt-2">
                <a href="/" class="text-blue-600 hover:underline text-sm">Volver al inicio</a>
            </div>
        </form>
    </div>
</body>
</html>